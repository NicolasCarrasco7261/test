pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                echo 'No hay código que compilar (proyecto HTML).'
            }
        }

        stage('Test') {
            steps {
                bat 'if exist hola.html (echo Archivo HTML encontrado) else (exit /b 1)'
            }
        }

        stage('Deploy') {
            steps {
                bat 'start "" hola.html'
            }
        }
    }
}